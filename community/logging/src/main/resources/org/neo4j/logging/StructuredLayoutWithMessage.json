{
  "time": {
    "$resolver": "timestamp",
    "pattern": {
      "format": "yyyy-MM-dd HH:mm:ss.SSSZ",
      "timeZone": "UTC"
    }
  },
  "level": {
    "$resolver": "level",
    "field": "name"
  },
  "marker": {
    "parents":{
      "$resolver": "marker",
      "field": "parents"
    },
    "name":{
      "$resolver": "marker",
      "field": "name"
    }
  },
  "category": {
    "$resolver": "pattern",
    "pattern": "%c{1.}",
    "stackTraceEnabled": false
  },
  "message": {
    "$resolver": "pattern",
    "pattern": "%m",
    "stackTraceEnabled": false
  },
  "includeFullMap": {
    "$resolver": "map",
    "flatten": true
  },
  "stacktrace": {
    "$resolver": "exception",
    "field": "stackTrace",
    "stackTrace": {
      "stringified": true
    }
  }
}
