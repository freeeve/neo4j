<Configuration monitorInterval="5">

    <Appenders>
        <RollingFile name="RollingFile" fileName="${config:server.directories.logs}/debug.log"
                     filePattern="${config:server.directories.logs}/debug.log.%02i"
                     immediateFlush="true">
            <Neo4jDebugLogLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSSZ}{GMT+0} %-5p [%c{1.}] %m%n"/>
            <Policies>
                <SizeBasedTriggeringPolicy size="200 B"/>
            </Policies>
            <DefaultRolloverStrategy fileIndex="min" max="7"/>
        </RollingFile>
    </Appenders>

    <Loggers>
        <Root level="info">
            <AppenderRef ref="RollingFile"/>
        </Root>
    </Loggers>

</Configuration>
