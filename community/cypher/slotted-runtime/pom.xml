  <build>
    <plugins>
      <plugin>
        <groupId>net.alchim31.maven</groupId>
        <artifactId>scala-maven-plugin</artifactId>
        <version>${scala-maven-plugin.version}</version>

        <configuration>
          <scalaVersion>${scala3.version}</scalaVersion>
          <scalaCompatVersion>3</scalaCompatVersion>
          <recompileMode>${scala.plugin.recompileMode}</recompileMode>
          <args>
            <!-- NOTE: We do not use combine.children="append" here since parent specifies some args that are invalid for Scala 3 -->
            <!-- This means we have to manually sync if new args are added only to parent poms -->
            <arg>-Wunused:imports,privates,locals</arg>
            <!-- Silence Scala 3 syntax deprecation warnings -->
            <arg>-Wconf:cat=deprecation:s,id=E147:s,msg=.*can be rewritten automatically.*:s</arg>
          </args>
          <jvmArgs>
            <jvmArg>-Xms256m</jvmArg>
            <jvmArg>-Xmx1024m</jvmArg>
            <jvmArg>-Xss4M</jvmArg>
          </jvmArgs>
          <secondaryCacheDir>${java.io.tmpdir}</secondaryCacheDir>
        </configuration>
      </plugin>
      <plugin>
        <groupId>com.diffplug.spotless</groupId>
        <artifactId>spotless-maven-plugin</artifactId>
        <configuration>
          <scala>
            <scalafmt>
              <scalaMajorVersion>2.13</scalaMajorVersion>
              <file>${maven.multiModuleProjectDirectory}/public/build-resources/scalafmt3.conf</file>
            </scalafmt>
          </scala>
        </configuration>
      </plugin>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-dependency-plugin</artifactId>
        <executions>
          <execution>
            <id>analyze</id>
            <goals>
              <goal>analyze-only</goal>
            </goals>
            <configuration>
              <failOnWarning>true</failOnWarning>
              <ignoredUnusedDeclaredDependencies>
                <ignoredUnusedDeclaredDependency>org.scalatest:*</ignoredUnusedDeclaredDependency>
                <ignoredUnusedDeclaredDependency>co.helmethair:scalatest-junit-runner</ignoredUnusedDeclaredDependency>
                <ignoredUnusedDeclaredDependency>org.junit.jupiter:junit-jupiter</ignoredUnusedDeclaredDependency>
                <!-- Not sure why this is needed, module fails to compile without this dependency. -->
                <ignoredUnusedDeclaredDependency>org.neo4j:neo4j-cypher-logical-plan-builder</ignoredUnusedDeclaredDependency>
                <!-- Scala 3 macros and test utils are used indirectly -->
                <ignoredUnusedDeclaredDependency>org.neo4j:neo4j-cypher-macros-scala3</ignoredUnusedDeclaredDependency>
                <ignoredUnusedDeclaredDependency>org.neo4j:neo4j-test-util</ignoredUnusedDeclaredDependency>
                <ignoredUnusedDeclaredDependency>org.neo4j:neo4j-test-util-scala3</ignoredUnusedDeclaredDependency>
              </ignoredUnusedDeclaredDependencies>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>

  <profiles>
    <profile>
      <id>scala-fatal-warnings</id>
      <activation>
        <property>
          <name>scalaFatalWarnings</name>
          <value>true</value>
        </property>
      </activation>
      <build>
        <plugins>
          <plugin>
            <groupId>net.alchim31.maven</groupId>
            <artifactId>scala-maven-plugin</artifactId>
            <configuration>
              <args combine.self="override">
                <arg>-Xfatal-warnings</arg>
                <arg>-feature</arg>
                <arg>-Wunused:imports,privates,locals</arg>
                <!-- Silence Scala 3 syntax deprecation warnings -->
                <arg>-Wconf:cat=deprecation:s,id=E147:s,msg=.*can be rewritten automatically.*:s</arg>
              </args>
            </configuration>
          </plugin>
        </plugins>
      </build>
    </profile>
  </profiles>

