{
  "request": {
    "urlPath": "/openai/v1/responses",
    "method": "POST",
    "headers": {
      "Content-Type": {
        "equalTo": "application/json; charset=UTF-8"
      },
      "Authorization": {
        "equalTo": "Bearer dummy-azure-token"
      },
      "User-Agent": {
        "equalTo": "Neo4j-GenAIProcedures/1.2.0"
      }
    },
    "bodyPatterns": [
      {
        "equalToJson": {
          "model": "gpt-5",
          "input": [
            {
              "role": "user",
              "content": "Hello!"
            }
          ],
          "store": false,
          "max_output_tokens": 1024
        }
      }
    ]
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "bodyFileName": "azure-openai-v1-responses-create-response.json",
    "transformers": ["response-template"],
    "transformerParameters": {
      "answer": "Jag tog korven! (azure-openai)"
    }
  }
}