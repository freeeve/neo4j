  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "bodyFileName": "vertexai-v1-generate-content-response.json",
    "transformers": ["response-template"],
    "transformerParameters": {
      "answer": "Jag tog korven! (vertexai)"
    }
  }
